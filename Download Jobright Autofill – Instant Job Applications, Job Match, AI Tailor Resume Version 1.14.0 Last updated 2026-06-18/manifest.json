  "manifest_version": 3,
  "action": {
    "default_icon": {
      "16": "icon16.plasmo.6c567d50.png",
      "32": "icon32.plasmo.76b92899.png",
      "48": "icon48.plasmo.aced7582.png",
      "64": "icon64.plasmo.8bb5e6e0.png",
      "128": "icon128.plasmo.3c1ed2d2.png"
    }
  },
  "version": "1.14.0",
  "version_name": "1.14.0 Full-Auto Edition (CSV Queue, updated 2026-06-18)",
  "author": "Jobright.ai",
  "name": "Jobright Autofill – Instant Job Applications, Job Match, AI Tailor Resume",
  "description": "v1.14.0 (updated 2026-06-18): 1-click autofill for 150+ ATS platforms — now with fully-automated, zero-supervision applying. Upload a CSV of job URLs and the LazyApply-style queue opens each one, runs Jobright autofill, commits location/required fields and submits, with Pause / Skip / Quit / Speed controls. Native 1.14.0 UI/UX preserved. Trusted by 500K+ job seekers.",
  "background": {
    "service_worker": "static/background/index.js"
  },
  "permissions": [
    "storage",
    "declarativeNetRequest",
    "tabs",
    "cookies",
    "activeTab",
    "scripting"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "ua-enhancement.js"
      ],
      "css": [],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "click-jr-injector.62a5c2f4.js"
      ],
      "css": []
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "constants.90d51f50.js"
      ],
      "css": []
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "filler.17f3ba95.js"
      ],
      "css": []
    },
    {
      "matches": [
        "https://jobright.ai/jobs/info/*",
        "https://preprod.jobright.ai/jobs/info/*",
        "https://beta.jobright-internal.com/jobs/info/*",
        "https://dev.jobright-internal.com/jobs/info/*"
      ],
      "js": [
        "scroll-to-anchor.45fefb1b.js"
      ],
      "run_at": "document_idle",
      "css": []
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "contents.04ff201a.js"
      ],
      "css": [
        "inter.4ccb0dc5.css",
        "contents.191c3fd8.css"
      ],
      "all_frames": true,
      "exclude_matches": [
        "*://*.cloudflare.com/*",
        "https://li.protechts.net/*",
        "https://cs.ns1p.net/*",
        "https://merchantpool1.linkedin.com/*",
        "https://www.googletagmanager.com/*",
        "https://*.fls.doubleclick.net/activityi*",
        "https://lnkd.demdex.net/*",
        "https://www.google.com/recaptcha/enterprise/*",
        "https://crcldu.com/*"
      ],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*",
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "answer.d77729c7.js",
        "click-jr-injector.62a5c2f4.js",
        "dom.ed166d80.js",
        "constants.90d51f50.js",
